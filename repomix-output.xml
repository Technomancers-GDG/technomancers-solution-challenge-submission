      expect(formatDistance(125.5)).toBe("125.5 km");
      expect(formatDistance(0.5)).toBe("500 m");
    });

    it("should handle null values", () => {
      expect(formatDistance(null)).toBe("N/A");
    });
  });

  describe("formatRelativeTime", () => {
