                  <tbody>
                    {facilities.map((facility) => (
                      <tr key={facility.id}>
                        <td>{facility.name}</td>
                        <td>{facility.city}</td>
                        <td>{facility.facility_type}</td>
                        <td>{facility.base_capacity_units.toLocaleString()}</td>
                        <td>{facility.current_inventory_units.toLocaleString()}</td>
                      </tr>
