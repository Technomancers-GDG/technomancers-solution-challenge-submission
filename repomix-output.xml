COPY frontend/ .
RUN npm ci && npm run build

# Server stage
FROM python:3.11
WORKDIR /app
COPY --from=builder /app/dist ./frontend/dist
COPY backend/ .
RUN pip install -r requirements.txt
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
